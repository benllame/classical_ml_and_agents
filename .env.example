# ──────────────────────────────────────────────────────────────────────────────
# Environment Variables — Churn Intelligence System v3
# Copy to .env and fill in your values. NEVER commit the .env file.
# ──────────────────────────────────────────────────────────────────────────────

# --- LLM API Key ---
GOOGLE_API_KEY=

# --- LLM Config ---
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash   
LLM_TEMPERATURE=0.0

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=churn-benchmark
MLFLOW_MODEL_NAME=churn-predictor

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# --- Streamlit ---
STREAMLIT_PORT=8501

# --- Data ---
DATA_RAW_PATH=data/raw/WA_Fn-UseC_-Telco-Customer-Churn.csv
DATA_PROCESSED_PATH=data/processed/telco_churn_processed.csv
